OPENAI_API_KEY=
PILLSCAN_OPENAI_MODEL=gpt-5.4-mini
PILLSCAN_OPENAI_IMAGE_DETAIL=high
PILLSCAN_MAX_IMAGE_DIMENSION=2048
PILLSCAN_ENVIRONMENT=development
PILLSCAN_HOST=0.0.0.0
PILLSCAN_PORT=8000
PILLSCAN_LOG_FORMAT=console
PILLSCAN_ANALYSES_PER_MINUTE=20
PILLSCAN_MAX_CONCURRENT_ANALYSES=2
PILLSCAN_RATE_LIMIT_WAIT_SECONDS=5
PILLSCAN_TFDA_CATALOG_PATH=.data/tfda/catalog.sqlite3
PILLSCAN_TFDA_RAW_DIR=.data/tfda/raw
PILLSCAN_NHIA_DRUG_CSV_PATH=.data/nhia/drugs.csv
PILLSCAN_TFDA_CATALOG_REQUIRED=true
# Required when PILLSCAN_ENVIRONMENT=production.
PILLSCAN_API_TOKEN=
PILLSCAN_TRUSTED_HOSTS=["localhost","127.0.0.1","rpi.local"]
PILLSCAN_CORS_ORIGINS=[]
